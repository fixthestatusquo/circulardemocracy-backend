{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*", "test/**/*", "bin/**/*.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist", "supabase/functions/**/*"]
}
