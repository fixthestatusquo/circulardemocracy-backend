{
  "name": "circulardemocracy-backend",
  "version": "1.1.1",
  "description": "Backend API for Circular Democracy - processing citizen messages to politicians",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx src/serve.ts",
    "fetch": "tsx bin/fetch.ts",
    "mail": "tsx bin/mail.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "wrangler:dev": "wrangler dev src/index.ts --local",
    "deploy": "wrangler deploy --minify src/index.ts --env ",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint src/",
    "lint:fix": "biome lint src/ --write",
    "format": "biome format src/",
    "format:fix": "biome format src/ --write",
    "check": "biome check src/",
    "check:fix": "biome check src/ --write",
    "doc:spec": "tsx bin/spec-generate.ts",
    "doc:html": "redocly build-docs doc/openapi.json --output doc/openapi.html",
    "doc:md": "tsx bin/doc-generate.ts markdown",
    "doc:build": "npm run doc:spec && npm run doc:html && npm run doc:md",
    "client:build": "npx swagger-typescript-api generate --path ./doc/openapi.json -o ./src/client -n api.ts",
    "db:start": "supabase start",
    "type": "npx supabase gen types typescript --linked > src/types/supabase.ts",
    "db:push": "npx supabase db push --linked",
    "db:diff": "supabase db diff -f",
    "functions:deploy": "supabase functions deploy",
    "functions:deploy:user-sync": "supabase functions deploy user-sync --no-verify-jwt",
    "model:preload": "tsx scripts/preload-model.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@supabase/supabase-js": "^2.106.2",
    "@xenova/transformers": "^2.17.2",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.3.1",
    "hono": "^4.12.23",
    "jmap-cli": "^2.3.0",
    "marked": "^18.0.4",
    "turndown": "^7.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cloudflare/workers-types": "^4.20260525.1",
    "@hono/node-server": "^2.0.4",
    "@redocly/cli": "^2.31.4",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.9.1",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.7",
    "minimist": "^1.2.8",
    "swagger-typescript-api": "^13.10.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.94.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
